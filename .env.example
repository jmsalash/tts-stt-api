# Copy to .env and edit. All values optional (sensible defaults shown).

# --- server ---
HOST=0.0.0.0
PORT=8000
# Comma-separated bearer tokens required by clients. Leave empty to disable auth.
API_KEYS=
CORS_ORIGINS=*
MAX_UPLOAD_MB=50

# --- provider selection ---
TTS_PROVIDER=xtts            # xtts (local) | elevenlabs (cloud)
STT_PROVIDER=faster_whisper  # faster_whisper (local) | openai (cloud)
DEFAULT_LANGUAGE=en

# --- local TTS: XTTS-v2 ---
XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_DEVICE=auto             # auto | cuda | cpu

# --- local STT: faster-whisper ---
# tiny|base|small|medium|large-v3  (small is the default to save disk)
WHISPER_MODEL=small
WHISPER_DEVICE=auto          # auto | cuda | cpu
WHISPER_COMPUTE_TYPE=auto    # auto | int8 | int8_float16 | float16 | float32
WHISPER_BEAM_SIZE=5
WHISPER_VAD=true

# --- cloud TTS: ElevenLabs (only if TTS_PROVIDER=elevenlabs) ---
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- cloud STT: OpenAI (only if STT_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
OPENAI_BASE_URL=https://api.openai.com/v1
